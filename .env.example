# ============================================
# Trafic Provider - Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,rankpulse.cloud,www.rankpulse.cloud

# App Identity
APP_NAME=RankPulse
APP_DOMAIN=rankpulse.cloud
APP_URL=https://rankpulse.cloud

# Database (SQLite by default, PostgreSQL in production)
DB_ENGINE=sqlite3
# DB_ENGINE=postgresql
# DB_NAME=rankpulse
# DB_USER=postgres
# DB_PASSWORD=
# DB_HOST=localhost
# DB_PORT=5432

# ============================================
# Google Analytics 4 - Measurement Protocol
# ============================================
# Get API secret from: GA4 → Admin → Data Streams → Measurement Protocol API secrets
GA4_MEASUREMENT_ID=G-BCGGTGQJR9
GA4_API_SECRET=

# ============================================
# Google Search Console
# ============================================
# Service account JSON key file path
# Create at: https://console.cloud.google.com/iam-admin/serviceaccounts
GSC_SERVICE_ACCOUNT_KEY_PATH=credentials/gsc_service_account.json
GSC_SITE_URL=https://beezle.io

# ============================================
# Google Analytics Data API (GA4 Reporting)
# ============================================
GA4_PROPERTY_ID=
GA4_SERVICE_ACCOUNT_KEY_PATH=credentials/ga4_service_account.json

# ============================================
# OpenAI (Content Generation)
# ============================================
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# ============================================
# Target Site Configuration (Beezle)
# ============================================
SITE_NAME=Beezle
SITE_DOMAIN=beezle.io
SITE_URL=https://beezle.io

# ============================================
# VPS / Deploy (Paramiko SSH)
# ============================================
VPS_HOST=31.97.171.87
VPS_USER=root
VPS_PASSWORD=
VPS_PROJECT_PATH=/root/rankpulse
GUNICORN_PORT=8002

# ============================================
# GitHub
# ============================================
GITHUB_REPO=charliba/rankpulse
GITHUB_TOKEN=

# ============================================
# Email Notifications
# ============================================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_REPORT_RECIPIENTS=

# ============================================
# Celery (Task Queue - optional)
# ============================================
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ============================================
# Stripe
# ============================================
STRIPE_ACCOUNT_ID=acct_xxxx
STRIPE_PUBLIC_KEY=sua_public_key_aqui
STRIPE_SECRET_KEY=sua_secret_key_aqui
STRIPE_WEBHOOK_SECRET=seu_webhook_id_aqui
STRIPE_WEBHOOK_ENDPOINT_ID=seu_endpoint_id_aqui
STRIPE_WEBHOOK_URL=https://app.rankpulse.cloud/api/webhook/stripe/
